# OpAgent 环境变量示例
#
# 配置加载优先级（高 → 低）：
#   1. CLI 参数（--allow-write 等）
#   2. process.env（真实环境变量 + Bun 自动加载的 cwd .env）
#   3. ~/.op_agent/.env 全局配置文件（仅填充前两层未设置的键）
#
# 两种 .env 用法：
#   - 项目根 .env     ：Bun 启动时自动加载（项目级覆盖）
#   - ~/.op_agent/.env：全局兜底，所有项目共享（本文件）

# DeepSeek API 密钥（默认模型 deepseek/deepseek-v4-flash）
DEEPSEEK_API_KEY=sk-xxxxxxxx

# 覆盖模型：provider/model，如 anthropic/claude-sonnet-4-5、openai/gpt-4o
# OPAGENT_MODEL=deepseek/deepseek-v4-flash

# 配置目录（默认 ~/.op_agent）
# OPAGENT_DIR=~/.op_agent

# 开启写操作（等同 --allow-write）
# OPAGENT_ALLOW_WRITE=1

# 开启破坏性操作通道（等同 --allow-destructive）
# OPAGENT_ALLOW_DESTRUCTIVE=1

# 启用 LLM 语义审计（等同 --llm_audit）：写/破坏性命令与脚本额外过 LLM 审计
# OPAGENT_LLM_AUDIT=1

# LLM 审计端点与模型（默认 DeepSeek；可独立配置用更便宜模型）
# OPAGENT_AUDIT_BASE_URL=https://api.deepseek.com
# OPAGENT_AUDIT_MODEL=deepseek-chat
# OPAGENT_AUDIT_API_KEY=sk-xxxxxxxx

# 写白名单路径（冒号分隔）
# OPAGENT_WRITE_PATHS=/data/app:/var/www

# 审计 DB 路径（默认 ~/.op_agent/audit.db）
# OPAGENT_AUDIT_DB=~/.op_agent/audit.db
